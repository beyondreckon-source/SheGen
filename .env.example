# LLM - Use either Groq OR custom endpoint (when Groq is restricted)

# Option 1: Groq (default)
GROQ_API_KEY=your_groq_api_key_here

# Option 2: Custom endpoint (e.g. TCS genailab) - uncomment and set to use
# LLM_BASE_URL=https://genailab.tcs.in/v1
# LLM_MODEL=azure_ai/genailab-maas-DeepSeek-V3-0324
# LLM_API_KEY=your_api_key
# SSL_VERIFY=false

# Database
DATABASE_URL=sqlite+aiosqlite:///./moderation.db

# Application
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# Frontend (for CORS)
FRONTEND_URL=http://localhost:3000
